# ─── Wallet / RPC ───────────────────────────────────────────────────────
# WalletConnect / Reown project id (free, https://cloud.reown.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Mantle RPCs (override for paid providers)
NEXT_PUBLIC_MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_MANTLE_MAINNET_RPC=https://rpc.mantle.xyz

# ─── Squadium contract addresses (fill after `forge script Deploy.s.sol`) ──
NEXT_PUBLIC_AGENT_REGISTRY_SEPOLIA_ADDRESS=
NEXT_PUBLIC_SQUADIUM_SEPOLIA_ADDRESS=
NEXT_PUBLIC_LIQUID_REPUTATION_SEPOLIA_ADDRESS=
NEXT_PUBLIC_REWARD_DISTRIBUTOR_SEPOLIA_ADDRESS=
NEXT_PUBLIC_SORTINO_ORACLE_SEPOLIA_ADDRESS=

# Mainnet (W3-W4)
NEXT_PUBLIC_AGENT_REGISTRY_MAINNET_ADDRESS=
NEXT_PUBLIC_SQUADIUM_MAINNET_ADDRESS=
NEXT_PUBLIC_LIQUID_REPUTATION_MAINNET_ADDRESS=
NEXT_PUBLIC_REWARD_DISTRIBUTOR_MAINNET_ADDRESS=
NEXT_PUBLIC_SORTINO_ORACLE_MAINNET_ADDRESS=

# ─── Indexer ────────────────────────────────────────────────────────────
# Squadium indexer base URL (Ponder GraphQL + REST)
NEXT_PUBLIC_INDEXER_URL=http://localhost:42069
